# Streamlit secrets template.
#
# Streamlit Cloud:  Settings → Secrets → paste the line below with your real key.
# Local dev:        copy this file to .streamlit/secrets.toml (git-ignored) and
#                   fill in the key, OR export FOOTBALL_API_KEY in your shell.
#
# Get a key at https://www.football-data.org/

FOOTBALL_API_KEY = "your-football-data-org-key"
